# ============================================================================
# Terraform
# ============================================================================
# Local .terraform directories
**/.terraform/*
.terraform/
.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*
**/terraform.tfstate.d/*

# Plan files
*.plan

# Variable files with secrets
terraform.tfvars
**/.env

# Backend configuration files
backend.tf
*-backend.config

# ============================================================================
# HashiCorp Licenses
# ============================================================================
*.hclic

# ============================================================================
# Python
# ============================================================================
**/__pycache__/*
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
*.egg-info/

# ============================================================================
# IDE and Editor
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================================
# AI Assistant Directories
# ============================================================================
.bob/
.claude/
.gemini/
.zed/

# ============================================================================
# Project Documentation (AI-specific)
# ============================================================================
AGENTS.md
CLAUDE.md
GEMINI.md

# ============================================================================
# Project-Specific
# ============================================================================
.plans/

# Nomad job variable files with environment-specific values
jobs/**/*.hcl
!jobs/**/*.hcl.example

# Monte Carlo job data and results
jobs/monte-carlo/data/
jobs/monte-carlo/results/

# ============================================================================
# Backup and Temporary Files
# ============================================================================
*.bak
*.tmp
.tmp/
notes.txt
